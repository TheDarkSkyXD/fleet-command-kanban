{
  "name": "@fleet-command/daemon",
  "version": "4.5.6",
  "description": "Multi-agent software engineering daemon",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fleet-command": "./bin/fleet-command.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path'),s='src/system-agents/agents',d='dist/system-agents/agents';fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))\"",
    "start": "node dist/index.js",
    "dev": "tsc && (node bin/fleet-command.js start || exit 0)",
    "dev:watch": "tsc -b -w & NODE_ENV=development node --watch dist/index.js",
    "test": "node --experimental-test-module-mocks --test dist/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@fleet-command/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.14.1",
    "better-sqlite3": "^12.6.2",
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.1.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.30",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ]
}
