{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.fleet-command.app",
  "productName": "Fleet Command Kanban",
  "artifactName": "Fleet-Command-Kanban-Setup-${version}.${ext}",
  "directories": {
    "output": "release"
  },
  "publish": {
    "provider": "github",
    "owner": "TheDarkSkyXD",
    "repo": "fleet-command-kanban"
  },
  "npmRebuild": false,
  "files": [
    "out/**/*"
  ],
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*",
    "node_modules/node-pty/**/*"
  ],
  "extraResources": [
    {
      "from": "build/daemon",
      "to": "daemon",
      "filter": ["**/*"]
    },
    {
      "from": "../frontend/dist",
      "to": "frontend"
    },
    {
      "from": "build/icon.png",
      "to": "icon.png"
    },
    {
      "from": "build/icon.ico",
      "to": "icon.ico"
    }
  ],
  "afterPack": "./scripts/copy-native-modules.cjs",
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "build/icon.icns"
  },
  "win": {
    "target": ["nsis", "zip"],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "shortcutName": "Fleet Command Kanban",
    "include": "build/installer.nsh"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "build/icon.png"
  }
}
