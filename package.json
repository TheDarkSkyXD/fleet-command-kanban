{
  "name": "fleet-command-monorepo",
  "version": "5.0.1",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "rebuild:node": "node scripts/rebuild-native.cjs node && pnpm run fix:node-pty",
    "rebuild:electron": "node scripts/rebuild-native.cjs electron",
    "dev": "pnpm --parallel --filter @fleet-command/daemon --filter @fleet-command/frontend --filter @fleet-command/desktop dev",
    "start": "pnpm --parallel --filter @fleet-command/daemon --filter @fleet-command/frontend --filter @fleet-command/desktop dev",
    "build": "pnpm -r build && pnpm run fix:node-pty",
    "fix:node-pty": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "build:shared": "pnpm --filter @fleet-command/shared build",
    "build:daemon": "pnpm --filter @fleet-command/daemon build",
    "build:frontend": "pnpm --filter @fleet-command/frontend build",
    "build:desktop": "pnpm --filter @fleet-command/desktop build",
    "typecheck": "tsc --build",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
